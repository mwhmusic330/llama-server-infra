[Unit]
Description=llama.cpp server
After=network-online.target

[Service]
ExecStart=/opt/llama.cpp/build/bin/llama-server \
  -m /opt/llama.cpp/models/model.gguf \
  --host 0.0.0.0 --port 8080 \
  -ngl 99 \
  --ctx-size 16384 --parallel 1 --repeat-penalty 1.1 --frequency-penalty 0.01 --chat-template-file /opt/llama.cpp/llama3-tool-template.jinja

User=michael
Group=michael
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
